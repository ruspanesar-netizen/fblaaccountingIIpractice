const YEAR_OPTIONS = ["All", 2016, 2018, 2019, 2021];

function shuffleArray(items) {
  const copy = [...items];
  for (let i = copy.length - 1; i > 0; i--) {
    const j = Math.floor(Math.random() * (i + 1));
    [copy[i], copy[j]] = [copy[j], copy[i]];
  }
  return copy;
}

export default function FBLAAccountingPracticeSite() {
  const [yearFilter, setYearFilter] = useState("All");
  const [shuffleOn, setShuffleOn] = useState(true);
  const [seed, setSeed] = useState(0);
  const [index, setIndex] = useState(0);
  const [selected, setSelected] = useState(null);
  const [checked, setChecked] = useState(false);
  const [results, setResults] = useState({});

  const filteredQuestions = useMemo(() => {
    const base = yearFilter === "All"
      ? QUESTION_BANK
      : QUESTION_BANK.filter((q) => q.year === yearFilter);
    return shuffleOn ? shuffleArray(base) : base;
  }, [yearFilter, shuffleOn, seed]);

  const current = filteredQuestions[index] ?? null;
  const attemptedCount = Object.keys(results).length;
  const correctCount = Object.values(results).filter(Boolean).length;
  const progress = filteredQuestions.length
    ? Math.round((attemptedCount / filteredQuestions.length) * 100)
    : 0;

  const resetSession = () => {
    setIndex(0);
    setSelected(null);
    setChecked(false);
    setResults({});
    setSeed((s) => s + 1);
  };

  const nextQuestion = () => {
    if (!filteredQuestions.length) return;
    setSelected(null);
    setChecked(false);
    setIndex((prev) => (prev + 1 < filteredQuestions.length ? prev + 1 : 0));
  };

  const submitAnswer = () => {
    if (!current || !selected || checked) return;
    const isCorrect = selected === current.correct;
    setChecked(true);
    setResults((prev) => ({ ...prev, [current.id]: isCorrect }));
  };

  const answerStatus = checked
    ? selected === current?.correct
      ? "correct"
      : "wrong"
    : "idle";

  return (
    <div className="min-h-screen bg-slate-50 p-6">
      <div className="mx-auto grid max-w-7xl gap-6 lg:grid-cols-[320px,1fr]">
        <Card className="rounded-3xl border-0 shadow-sm">
          <CardHeader>
            <CardTitle className="text-2xl">FBLA Accounting II Trainer</CardTitle>
            <CardDescription>
              Practice multiple-choice questions with instant feedback.
            </CardDescription>
          </CardHeader>
          <CardContent className="space-y-6">
            <div>
              <p className="mb-3 text-sm font-medium text-slate-700">Filter by year</p>
              <div className="flex flex-wrap gap-2">
                {YEAR_OPTIONS.map((option) => {
                  const active = yearFilter === option;
                  return (
                    <Button
                      key={String(option)}
                      variant={active ? "default" : "outline"}
                      className="rounded-2xl"
                      onClick={() => {
                        setYearFilter(option);
                        setIndex(0);
                        setSelected(null);
                        setChecked(false);
                        setResults({});
                        setSeed((s) => s + 1);
                      }}
                    >
                      {option}
                    </Button>
                  );
                })}
              </div>
            </div>

            <div className="space-y-3">
              <div className="flex items-center justify-between">
                <p className="text-sm font-medium text-slate-700">Session progress</p>
                <span className="text-sm text-slate-500">{progress}%</span>
              </div>
              <Progress value={progress} className="h-3" />
              <div className="grid grid-cols-2 gap-3 text-sm">
                <div className="rounded-2xl bg-slate-100 p-3">
                  <div className="text-slate-500">Questions</div>
                  <div className="mt-1 text-xl font-semibold">{filteredQuestions.length}</div>
                </div>
                <div className="rounded-2xl bg-slate-100 p-3">
                  <div className="text-slate-500">Correct</div>
                  <div className="mt-1 text-xl font-semibold">{correctCount}</div>
                </div>
              </div>
            </div>

            <div className="space-y-3">
              <Button
                variant="outline"
                className="w-full justify-start rounded-2xl"
                onClick={() => {
                  setShuffleOn((v) => !v);
                  setIndex(0);
                  setSelected(null);
                  setChecked(false);
                  setResults({});
                  setSeed((s) => s + 1);
                }}
              >
                <Shuffle className="mr-2 h-4 w-4" />
                {shuffleOn ? "Shuffle: On" : "Shuffle: Off"}
              </Button>
              <Button variant="outline" className="w-full justify-start rounded-2xl" onClick={resetSession}>
                <RotateCcw className="mr-2 h-4 w-4" />
                Reset session
              </Button>
            </div>

            <div className="rounded-2xl bg-slate-100 p-4 text-sm text-slate-600">
              <p className="font-medium text-slate-800">How it works</p>
              <p className="mt-2">
                Pick an answer, hit <span className="font-semibold">Check answer</span>, and the site will tell you right away whether you are correct. If you miss it, you get the right answer and a short explanation.
              </p>
            </div>
          </CardContent>
        </Card>

        <div className="space-y-6">
          <Card className="rounded-3xl border-0 shadow-sm">
            <CardHeader>
              <div className="flex flex-wrap items-center gap-3">
                <Badge className="rounded-xl px-3 py-1 text-sm">{current ? `${current.year} · Q${current.number}` : "No questions"}</Badge>
                {current?.topic ? <Badge variant="secondary" className="rounded-xl px-3 py-1 text-sm">{current.topic}</Badge> : null}
              </div>
              <CardTitle className="text-xl leading-8">
                {current ? current.prompt : "No questions match the current filter."}
              </CardTitle>
            </CardHeader>
            <CardContent className="space-y-4">
              {current ? (
                <>
                  <div className="grid gap-3">
                    {Object.entries(current.choices).map(([letter, text]) => {
                      const isPicked = selected === letter;
                      const isCorrectChoice = checked && current.correct === letter;
                      const isWrongPicked = checked && isPicked && letter !== current.correct;

                      let classes = "w-full rounded-2xl border p-4 text-left transition ";
                      if (!checked) {
                        classes += isPicked
                          ? "border-slate-900 bg-slate-900 text-white"
                          : "border-slate-200 bg-white hover:border-slate-400";
                      } else if (isCorrectChoice) {
                        classes += "border-emerald-500 bg-emerald-50";
                      } else if (isWrongPicked) {
                        classes += "border-rose-500 bg-rose-50";
                      } else {
                        classes += "border-slate-200 bg-white opacity-80";
                      }

                      return (
                        <button
                          key={letter}
                          className={classes}
                          onClick={() => !checked && setSelected(letter)}
                        >
                          <div className="flex items-start gap-3">
                            <div className="flex h-8 w-8 shrink-0 items-center justify-center rounded-full border text-sm font-semibold">
                              {letter}
                            </div>
                            <div className="pt-1 text-base">{text}</div>
                          </div>
                        </button>
                      );
                    })}
                  </div>

                  <div className="flex flex-wrap gap-3 pt-2">
                    <Button className="rounded-2xl" onClick={submitAnswer} disabled={!selected || checked}>
                      Check answer
                    </Button>
                    <Button variant="outline" className="rounded-2xl" onClick={nextQuestion}>
                      Next question
                      <ChevronRight className="ml-2 h-4 w-4" />
                    </Button>
                  </div>

                  {checked && (
                    <div
                      className={`rounded-2xl border p-4 ${
                        answerStatus === "correct"
                          ? "border-emerald-300 bg-emerald-50"
                          : "border-rose-300 bg-rose-50"
                      }`}
                    >
                      <div className="flex items-center gap-2 text-base font-semibold">
                        {answerStatus === "correct" ? (
                          <>
                            <CheckCircle2 className="h-5 w-5" />
                            Correct
                          </>
                        ) : (
                          <>
                            <XCircle className="h-5 w-5" />
                            Not quite
                          </>
                        )}
                      </div>
                      <p className="mt-2 text-sm text-slate-700">
                        Correct answer: <span className="font-semibold">{current.correct}</span> — {current.choices[current.correct]}
                      </p>
                      <p className="mt-3 text-sm text-slate-700">{current.explanation}</p>
                    </div>
                  )}
                </>
              ) : (
                <div className="rounded-2xl bg-slate-100 p-6 text-slate-600">
                  Try switching the filter or resetting the session.
                </div>
              )}
            </CardContent>
          </Card>

          <Card className="rounded-3xl border-0 shadow-sm">
            <CardHeader>
              <CardTitle className="text-lg">Question bank included right now</CardTitle>
              <CardDescription>
                Seeded with extracted questions from the uploaded FBLA Accounting II exams.
              </CardDescription>
            </CardHeader>
            <CardContent>
              <div className="flex flex-wrap gap-2">
                {[2016, 2018, 2019, 2021].map((year) => {
                  const count = QUESTION_BANK.filter((q) => q.year === year).length;
                  return (
                    <Badge key={year} variant="secondary" className="rounded-xl px-3 py-1 text-sm">
                      {year}: {count} questions
                    </Badge>
                  );
                })}
              </div>
              <p className="mt-4 text-sm text-slate-600">
                The site is already functional for drilling questions with instant grading. It is structured so more questions can be added easily to the same question bank.
              </p>
            </CardContent>
          </Card>
        </div>
      </div>
    </div>
  );
}
